   "source": [
    "n = int(input())\n",
    "def mu(x):\n",
    "    somu = 0\n",
    "    while x != 0:\n",
    "        somu += 1\n",
    "        x //= 10\n",
    "    return somu\n",
    "\n",
    "def soarm(a):\n",
    "    tong = 0\n",
    "    while a != 0:\n",
    "        tong += (a%10)**mu(n)\n",
    "        a //= 10\n",
    "    return tong\n",
    "\n",
    "print(n == soarm(n))"
   ]
  }
